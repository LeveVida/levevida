# Headers do Netlify - Leve Vida
# Este arquivo DEVE estar na RAIZ do repositório

# Headers de segurança para todas as páginas
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdnjs.cloudflare.com https://www.googletagmanager.com https://pagead2.googlesyndication.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; img-src 'self' data: https:; font-src 'self' data: https://cdnjs.cloudflare.com;

# MIME types corretos para arquivos JavaScript
/assets/js/*.js
  Content-Type: application/javascript; charset=utf-8
  Cache-Control: public, max-age=31536000, immutable

/artigos/*.js
  Content-Type: application/javascript; charset=utf-8
  Cache-Control: public, max-age=3600

# Cache longo para assets estáticos
/assets/css/*
  Cache-Control: public, max-age=31536000, immutable

/assets/images/*
  Cache-Control: public, max-age=31536000, immutable

# Cache médio para guias
/guias/*
  Cache-Control: public, max-age=3600

# Cache curto para HTML
/*.html
  Cache-Control: public, max-age=3600

# Cache muito curto para JSON de conteúdo
/content/*.json
  Cache-Control: public, max-age=300
  
/guias/*/config.json
  Cache-Control: public, max-age=3600
